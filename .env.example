# Neon Postgres connection string. Provisioned via the Vercel Marketplace
# (`vercel install neon-postgres`) and injected into the project's environment
# automatically by Vercel. Local copy lives in .env.local (gitignored).
DATABASE_URL=

# NextAuth.js: long random string used to sign session JWTs / CSRF tokens.
# Generate with `openssl rand -base64 32`.
NEXTAUTH_SECRET=

# NextAuth.js: canonical URL of the deployed app (e.g. http://localhost:3000
# locally, https://<project>.vercel.app in prod).
NEXTAUTH_URL=
